// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  nickname  String?
  bio       String?
  subject             String?
  resetCode           String?
  resetCodeExpiresAt  DateTime?
  createdAt           DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages      Message[]
  channels      ChannelMember[]
  reactions     Reaction[]
  events        Event[]
  announcements Announcement[]
  connectionsA  Connection[]    @relation("ConnectorA")
  connectionsB  Connection[]    @relation("ConnectorB")

  createdResources Resource[]   @relation("CreatedResources")
  downloads        Download[]
  resourceReviews  ResourceReview[]

  @@index([username])
  @@index([nickname])
  @@index([subject])
}

model Channel {
  id          String   @id @default(uuid())
  name        String
  description String?
  tags        String?
  isPrivate   Boolean  @default(false)
  notebook    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    Message[]
  members     ChannelMember[]

  @@index([name])
  @@index([tags])
  @@index([isPrivate])
}

model ChannelMember {
  userId    String
  channelId String
  role      String   @default("MEMBER")
  isMuted   Boolean  @default(false)
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  channel   Channel  @relation(fields: [channelId], references: [id])

  @@id([userId, channelId])
}

model Message {
  id        String   @id @default(uuid())
  content   String?
  fileUrl   String?
  fileType  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  channelId String
  replyToId String?

  user      User       @relation(fields: [userId], references: [id])
  channel   Channel    @relation(fields: [channelId], references: [id])
  replyTo   Message?   @relation("ThreadReplies", fields: [replyToId], references: [id])
  replies   Message[]  @relation("ThreadReplies")
  reactions Reaction[]

  @@index([channelId])
  @@index([userId])
  @@index([createdAt])
}

model Reaction {
  id        String   @id @default(uuid())
  emoji     String
  createdAt DateTime @default(now())

  userId    String
  messageId String

  user      User     @relation(fields: [userId], references: [id])
  message   Message  @relation(fields: [messageId], references: [id])

  @@unique([userId, messageId, emoji])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  emoji       String   @default("📅")
  scheduledAt DateTime
  createdAt   DateTime @default(now())

  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
}

model Announcement {
  id        String   @id @default(uuid())
  title     String?
  content   String
  badge     String   @default("Notice")
  fileUrls  String?  // JSON array of file URLs
  fileTypes String?  // JSON array of mime types
  createdAt DateTime @default(now())

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}

model Connection {
  id          String   @id @default(uuid())
  status      String   @default("PENDING")  // PENDING | ACCEPTED
  createdAt   DateTime @default(now())

  userAId     String
  userBId     String

  userA       User     @relation("ConnectorA", fields: [userAId], references: [id])
  userB       User     @relation("ConnectorB", fields: [userBId], references: [id])

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([status])
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  author      String
  subject     String
  category    String   // "Book", "PDF", "Notes", "Lecture Slides"
  fileUrl     String
  fileType    String
  source      String   // "OpenStax", "Project Gutenberg", "MIT OCW", "Community"
  grade       String[] // ["High School", "College"]

  isbn        String?
  publishedYear Int?
  license     String   @default("CC BY 4.0")
  isActive    Boolean  @default(true)
  downloadCount Int    @default(0)

  creatorId   String?
  creator     User?    @relation("CreatedResources", fields: [creatorId], references: [id], onDelete: SetNull)

  tags        ResourceTag[]
  downloads   Download[]
  reviews     ResourceReview[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subject])
  @@index([category])
  @@index([source])
  @@index([title])
}

model ResourceTag {
  id          String   @id @default(cuid())
  name        String
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, name])
  @@index([resourceId])
}

model Download {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  downloadedAt DateTime @default(now())

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
}

model ResourceReview {
  id          String   @id @default(cuid())
  rating      Int      // 1-5 stars
  comment     String   @db.Text
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
}
